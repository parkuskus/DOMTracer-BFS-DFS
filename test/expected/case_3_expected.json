{
  "description": "Class selector with DFS and Top-N limit",
  "input": {
    "htmlFile": "test/cases/case03_limit_topn.html",
    "selector": ".entry",
    "algorithm": "DFS",
    "limit": 2,
    "includePathToMatch": false,
    "includeTraversalLog": false
