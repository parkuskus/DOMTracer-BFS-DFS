    "matches": [
      {
        "nodePath": "0/0/0/0",
        "tag": "li",
        "depth": 3,
        "visitStep": 4,
        "attributes": {
          "class": "entry"
        },
        "textSnippet": "One"
      },
      {
        "nodePath": "0/0/0/1",
        "tag": "li",
        "depth": 3,
        "visitStep": 5,
        "attributes": {
          "class": "entry"
        },
        "textSnippet": "Two"
      }
    ]
  }
}
